{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "uid": "ojo-docker",
  "title": "Ojo Docker",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": [
    "ojo",
    "docker"
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_docker_source_available, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_docker_source_available{job=~\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_docker_container_cpu_ratio{job=~\"$service\",instance=~\"$instance\",container_name!=\"\"}, container_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Source Available",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_docker_source_available{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Containers Total",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_docker_containers_total{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Containers Running",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_docker_containers_running{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 10,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Containers Stopped",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_docker_containers_stopped{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 15,
        "y": 0
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Labeled Containers",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (container_name) (system_docker_container_cpu_ratio{job=~\"$service\",instance=~\"$instance\",container_name!=\"\"}))"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Ratio by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * avg by (container_name) (system_docker_container_cpu_ratio{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"})",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Memory Usage by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (container_name) (system_docker_container_memory_usage_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"})",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Limit by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (container_name) (system_docker_container_memory_limit_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"})",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 12
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Network RX/s by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_name) (deriv(system_docker_container_network_rx_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"}[5m]))",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 19
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Network TX/s by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_name) (deriv(system_docker_container_network_tx_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"}[5m]))",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 19
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Block IO Read/s by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_name) (deriv(system_docker_container_block_read_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"}[5m]))",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 26
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Block IO Write/s by Container",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_name) (deriv(system_docker_container_block_write_bytes{job=~\"$service\",instance=~\"$instance\",container_name!=\"\",container_name=~\"$container\"}[5m]))",
          "legendFormat": "{{container_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 26
      }
    }
  ]
}
