{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "editable": true,
  "id": null,
  "uid": "ojo-nfs-client",
  "title": "Ojo NFS Client",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "tags": ["ojo", "nfs"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(system_nfs_client_source_available, service_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Source Available",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_nfs_client_source_available{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "NFS Mounts",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_nfs_client_mounts{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RPC Calls / Second",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(system_nfs_client_rpc_calls_rate_per_second{service_name=~\"$service\"})",
          "legendFormat": "RPC Calls/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RPC Retransmissions / Second",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(system_nfs_client_rpc_retransmissions_rate_per_second{service_name=~\"$service\"})",
          "legendFormat": "Retransmissions/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RPC Counters (Total)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(system_nfs_client_rpc_calls_total{service_name=~\"$service\"})",
          "legendFormat": "Calls"
        },
        {
          "refId": "B",
          "expr": "sum(system_nfs_client_rpc_retransmissions_total{service_name=~\"$service\"})",
          "legendFormat": "Retransmissions"
        },
        {
          "refId": "C",
          "expr": "sum(system_nfs_client_rpc_auth_refreshes_total{service_name=~\"$service\"})",
          "legendFormat": "Auth Refreshes"
        }
      ],
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 12 }
    }
  ]
}
