{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "title": "Ojo Systemd",
  "uid": "ojo-systemd",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "ojo",
    "systemd"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_systemd_source_available, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_systemd_source_available{job=~\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Systemd Collector Up",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systemd_up{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Source Availability",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systemd_source_available{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Units Total",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systemd_units_total{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed Units (Reported)",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systemd_failed_units_reported{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Unit States",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systemd_units_active{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systemd_units_inactive{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systemd_units_failed{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_systemd_units_activating{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "E",
          "expr": "system_systemd_units_deactivating{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "F",
          "expr": "system_systemd_units_reloading{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "G",
          "expr": "system_systemd_units_maintenance{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "H",
          "expr": "system_systemd_units_not_found{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Systemd Jobs",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systemd_jobs_queued{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systemd_jobs_running{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Unit Health Ratios",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systemd_units_active_ratio{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systemd_units_failed_ratio{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failed Units",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systemd_units_failed{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systemd_failed_units_reported{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
