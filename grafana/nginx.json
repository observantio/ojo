{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "title": "Ojo Nginx",
  "uid": "ojo-nginx",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "ojo",
    "nginx"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_nginx_source_available, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_nginx_source_available{job=~\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nginx Up",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_nginx_up{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Source Available",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_nginx_source_available{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Connections",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_nginx_connections_active{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Request Rate",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_nginx_requests_rate_per_second{job=~\"$service\",instance=~\"$instance\"} or rate(system_nginx_requests_total{job=~\"$service\",instance=~\"$instance\"}[1m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection States",
      "targets": [
        {
          "refId": "A",
          "expr": "system_nginx_connections_active{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_nginx_connections_reading{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_nginx_connections_writing{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_nginx_connections_waiting{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Traffic Rates",
      "targets": [
        {
          "refId": "A",
          "expr": "system_nginx_requests_rate_per_second{job=~\"$service\",instance=~\"$instance\"} or rate(system_nginx_requests_total{job=~\"$service\",instance=~\"$instance\"}[1m])"
        },
        {
          "refId": "B",
          "expr": "system_nginx_connections_accepted_rate_per_second{job=~\"$service\",instance=~\"$instance\"} or rate(system_nginx_connections_accepted_total{job=~\"$service\",instance=~\"$instance\"}[1m])"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Connection and Request Totals",
      "targets": [
        {
          "refId": "A",
          "expr": "system_nginx_connections_accepted_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_nginx_connections_handled_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_nginx_requests_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
