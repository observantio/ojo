{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "title": "Ojo Redis",
  "uid": "ojo-redis",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "ojo",
    "redis"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_redis_source_available, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_redis_source_available{job=~\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redis Up",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_up{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Source Available",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_source_available{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connected Clients",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_clients_connected{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Blocked Clients",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_clients_blocked{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Command Rate",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_commands_processed_rate_per_second{job=~\"$service\",instance=~\"$instance\"} or rate(system_redis_commands_processed_total{job=~\"$service\",instance=~\"$instance\"}[1m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Keyspace Hit Ratio",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_redis_keyspace_hit_ratio{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory",
      "targets": [
        {
          "refId": "A",
          "expr": "system_redis_memory_used_bytes{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_redis_memory_max_bytes{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Traffic Rates",
      "targets": [
        {
          "refId": "A",
          "expr": "system_redis_commands_processed_rate_per_second{job=~\"$service\",instance=~\"$instance\"} or rate(system_redis_commands_processed_total{job=~\"$service\",instance=~\"$instance\"}[1m])"
        },
        {
          "refId": "B",
          "expr": "system_redis_connections_received_rate_per_second{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Totals",
      "targets": [
        {
          "refId": "A",
          "expr": "system_redis_commands_processed_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_redis_connections_received_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_redis_uptime_seconds{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Keyspace and Evictions",
      "targets": [
        {
          "refId": "A",
          "expr": "system_redis_keyspace_hits_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_redis_keyspace_misses_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_redis_keys_expired_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_redis_keys_evicted_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
