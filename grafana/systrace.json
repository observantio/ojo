{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "title": "Ojo Systrace",
  "uid": "ojo-systrace",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "ojo",
    "systrace"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_systrace_source_available, job)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_systrace_source_available{job=~\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Systrace Up",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_up{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tracing Enabled",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_tracing_on{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Processes",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_processes_total{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Threads",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_threads_total{job=~\"$service\",instance=~\"$instance\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Scheduler Pressure",
      "description": "Collector-derived per-second gauges; PromQL rate() is not needed here.",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_run_queue_depth{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_context_switches_per_sec{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_process_forks_per_sec{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kernel Event Rates",
      "description": "Collector-derived per-second gauges; PromQL rate() is not needed here.",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_interrupts_per_sec{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_system_calls_per_sec{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_dpcs_per_sec{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Trace Facility Inventory",
      "targets": [
        {
          "refId": "S",
          "expr": "system_systrace_source_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "A",
          "expr": "system_systrace_tracefs_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_etw_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_tracers_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_systrace_etw_sessions_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "E",
          "expr": "system_systrace_etw_sessions_running{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "F",
          "expr": "system_systrace_etw_providers_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Trace Events Coverage",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_events_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_events_enabled{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "100 * system_systrace_events_enabled{job=~\"$service\",instance=~\"$instance\"} / clamp_min(system_systrace_events_total{job=~\"$service\",instance=~\"$instance\"}, 1)"
        },
        {
          "refId": "D",
          "expr": "system_systrace_event_categories_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Collector Reliability",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_collection_errors{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_exporter_errors_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_exporter_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_systrace_exporter_reconnecting{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "System Call Source and Coverage",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_system_calls_source{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "100 * system_systrace_system_calls_coverage_ratio{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Stack Sample Signals",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_trace_kernel_stack_samples_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_trace_user_stack_samples_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_trace_sample_lines_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Trace Buffer Capacity",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_buffer_total_kb{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Enabled Events Inventory and Syscall Hooks",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_events_enabled_inventory_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_syscalls_enter_enabled{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_syscalls_exit_enabled{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "High-Value Category Coverage",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_coverage_high_value_categories_targeted{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_coverage_high_value_categories_enabled{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "100 * system_systrace_coverage_high_value_categories_enabled{job=~\"$service\",instance=~\"$instance\"} / clamp_min(system_systrace_coverage_high_value_categories_targeted{job=~\"$service\",instance=~\"$instance\"}, 1)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 45
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Trace Stream Continuity",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_trace_stream_lines_captured_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_trace_stream_continuity{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 53
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Trace Loss and Overrun",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_trace_dropped_events_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_trace_overrun_events_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 53
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Privilege and Probe Capability",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_privileged_mode{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_ebpf_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_uprobes_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "D",
          "expr": "system_systrace_usdt_available{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "E",
          "expr": "system_systrace_symbolizer_available{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Archive Pipeline Health",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_archive_writer_healthy{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_archive_events_total{job=~\"$service\",instance=~\"$instance\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_archive_bytes_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 61
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Runtime Probes Configured",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_runtime_probes_configured_total{job=~\"$service\",instance=~\"$instance\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 69
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
