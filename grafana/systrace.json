{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "editable": true,
  "id": null,
  "title": "Ojo Systrace",
  "uid": "ojo-systrace",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": [
    "ojo",
    "systrace"
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(system_systrace_source_available, service_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Systrace Up",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_up{service_name=~\"$service\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tracing Enabled",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_tracing_on{service_name=~\"$service\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Processes",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_processes_total{service_name=~\"$service\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Threads",
      "targets": [
        {
          "refId": "A",
          "expr": "max(system_systrace_threads_total{service_name=~\"$service\"})"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Scheduler Pressure",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_run_queue_depth{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_context_switches_per_sec{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_process_forks_per_sec{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kernel Event Rates",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_interrupts_per_sec{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_system_calls_per_sec{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_dpcs_per_sec{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Trace Facility Inventory",
      "targets": [
        {
          "refId": "S",
          "expr": "system_systrace_source_available{service_name=~\"$service\"}"
        },
        {
          "refId": "A",
          "expr": "system_systrace_tracefs_available{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_etw_available{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_tracers_available{service_name=~\"$service\"}"
        },
        {
          "refId": "D",
          "expr": "system_systrace_etw_sessions_total{service_name=~\"$service\"}"
        },
        {
          "refId": "E",
          "expr": "system_systrace_etw_sessions_running{service_name=~\"$service\"}"
        },
        {
          "refId": "F",
          "expr": "system_systrace_etw_providers_total{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Trace Events Coverage",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_events_total{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_events_enabled{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "100 * system_systrace_events_enabled{service_name=~\"$service\"} / clamp_min(system_systrace_events_total{service_name=~\"$service\"}, 1)"
        },
        {
          "refId": "D",
          "expr": "system_systrace_event_categories_total{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Collector Reliability",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_collection_errors{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_exporter_errors_total{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_exporter_available{service_name=~\"$service\"}"
        },
        {
          "refId": "D",
          "expr": "system_systrace_exporter_reconnecting{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "System Call Source and Coverage",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_system_calls_source{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "100 * system_systrace_system_calls_coverage_ratio{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Stack Sample Signals",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_trace_kernel_stack_samples_total{service_name=~\"$service\"}"
        },
        {
          "refId": "B",
          "expr": "system_systrace_trace_user_stack_samples_total{service_name=~\"$service\"}"
        },
        {
          "refId": "C",
          "expr": "system_systrace_trace_sample_lines_total{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Trace Buffer Capacity",
      "targets": [
        {
          "refId": "A",
          "expr": "system_systrace_buffer_total_kb{service_name=~\"$service\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ]
}
