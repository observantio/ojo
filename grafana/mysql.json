{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "editable": true,
  "id": null,
  "uid": "ojo-mysql",
  "title": "Ojo MySQL",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": ["ojo", "mysql"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(system_mysql_source_available, service_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Source Available",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_mysql_source_available{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "MySQL Up",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_mysql_up{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connections",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_mysql_connections{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Threads Running",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "max(system_mysql_threads_running{service_name=~\"$service\"})" }],
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queries / Second",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(system_mysql_queries_rate_per_second{service_name=~\"$service\"})",
          "legendFormat": "Queries/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network Bytes / Second",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(system_mysql_bytes_received_rate_per_second{service_name=~\"$service\"})",
          "legendFormat": "Received"
        },
        {
          "refId": "B",
          "expr": "sum(system_mysql_bytes_sent_rate_per_second{service_name=~\"$service\"})",
          "legendFormat": "Sent"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Query Counters (Total)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(system_mysql_queries_total{service_name=~\"$service\"})",
          "legendFormat": "Queries"
        },
        {
          "refId": "B",
          "expr": "sum(system_mysql_slow_queries_total{service_name=~\"$service\"})",
          "legendFormat": "Slow Queries"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network Bytes (Total)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(system_mysql_bytes_received_total{service_name=~\"$service\"})",
          "legendFormat": "Received"
        },
        {
          "refId": "B",
          "expr": "sum(system_mysql_bytes_sent_total{service_name=~\"$service\"})",
          "legendFormat": "Sent"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 }
    }
  ]
}
